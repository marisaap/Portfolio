    <title>Formulario
</title>
<link rel="stylesheeet" href="style.css">
</head>
<body>
    <form id="Formulario" 
    <div>
<label for="Marisa Aparecida Masini">nome:</label> 
<input 
type="Nome" 
id="marisa" name="marisa" 
placeholder="Marisa Aparecida Masini"
    </imput> </div>
    <div>
    <label for="email">nome:</label> 
<input 
type="email" 
id="email" name="email"
placeholder="marisa.masini@outlook.com" 
    </imput> </div>
<div>
    <label for="mensagem">nome:</label> 
    <input 
type="mensagem" 
id="mensagem" name="mensagem"
placeholder="mensagem" 
</imput> </div>
<button type="submit">Enviar</button>
</form>
